{
  "dependencies": {
    "mongodb": "^7.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "http-server": "^14.1.1",
    "mongodb-memory-server": "^11.0.1",
    "tailwindcss": "^3.4.17"
  },
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i ./frontend/assets/tailwind.input.css -o ./frontend/assets/tailwind.css --minify",
    "build:css:watch": "tailwindcss -c tailwind.config.js -i ./frontend/assets/tailwind.input.css -o ./frontend/assets/tailwind.css --watch",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:visual:headed": "playwright test --headed"
  }
}
